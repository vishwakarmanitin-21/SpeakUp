{
    "whisper_model": "gpt-4o-transcribe",
    "gpt_model": "gpt-4o-mini",
    "temperature": 0.2,
    "hotkey": "ctrl+cmd",
    "sample_rate": 16000,
    "silence_timeout_ms": 2000,
    "auto_stop_on_silence": false,
    "default_rewrite_mode": "smart",
    "output_mode": "auto_paste",
    "stream_output": true,
    "keep_on_clipboard": false,
    "include_clipboard": false,
    "include_selection": false,
    "include_session_memory": true,
    "transcription_provider": "cloud",
    "transcription_realtime": false,
    "whisper_local_model_size": "base",
    "custom_vocabulary": [],
    "include_vscode_file": false,
    "auto_start": false,
    "track_usage": true,
    "widget_position": "bottom_center",
    "widget_scale": "compact"
}
